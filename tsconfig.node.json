{
  "extends": "@electron-toolkit/tsconfig/tsconfig.node.json",
  "include": [
    "electron.vite.config.*",
    "src/main/**/*",
    "src/preload/**/*",
    "config/*",
    "src/types/**/*",
    "src/lib/**/*"
  ],
  "compilerOptions": {
    "composite": true,
    "types": [
      "electron-vite/node"
    ],
    "paths": {
      "@/types": [
        "./src/types"
      ],
      "@/types/*": [
        "./src/types/*"
      ],
      "@/*": [
        "./src/main/*"
      ]
    }
  }
}
