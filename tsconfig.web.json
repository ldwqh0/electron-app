{
  "extends": "@electron-toolkit/tsconfig/tsconfig.web.json",
  "include": [
    "src/renderer/src/env.d.ts",
    "src/renderer/src/**/*",
    "src/renderer/src/**/*.vue",
    "src/preload/*.d.ts",
    "src/lib/**/*",
    "src/types/**/*"
  ],
  "compilerOptions": {
    "composite": true,
    "ignoreDeprecations": "6.0",
    "baseUrl": ".",
    "paths": {
      "@/types": [
        "./src/types"
      ],
      "@/types/*": [
        "./src/types/*"
      ],
      "@/*": [
        "./src/renderer/src/*"
      ],
      "@lib/*": [
        "./src/lib/*"
      ]
    }
  }
}
